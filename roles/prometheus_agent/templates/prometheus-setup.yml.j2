global:
  scrape_interval: 15s
  external_labels:
    cluster: "k3s-cluster"

scrape_configs:
  - job_name: 'kubernetes-nodes-exporter'
    kubernetes_sd_configs:
      - role: node
    relabel_configs:
      - action: replace
        source_labels: [__address__]
        regex: '(.*):10250'
        replacement: '${1}:9100'
        target_label: __address__

remote_write:
  - url: "http://192.168.56.20:9090/api/v1/write"