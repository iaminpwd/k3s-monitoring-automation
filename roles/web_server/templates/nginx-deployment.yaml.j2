apiVersion: apps/v1
kind: Deployment
metadata:
  name: nginx-web
  namespace: default
spec:
  replicas: 2  # 노드가 2개니 2개로 설정하면 좋겠죠?
  selector:
    matchLabels:
      app: nginx-web
  template:
    metadata:
      labels:
        app: nginx-web
    spec:
      # [핵심 추가] 이 설정을 통해 'web' 라벨이 붙은 노드로만 배포됩니다.
      nodeSelector:
        node-role: web
      
      containers:
        # 1. Nginx 컨테이너
        - name: nginx
          image: nginx:latest
          ports:
            - containerPort: 80
          volumeMounts:
            - name: config-volume
              mountPath: /etc/nginx/conf.d/default.conf
              subPath: default.conf

        # 2. 사이드카: Nginx Exporter
        - name: nginx-exporter
          image: nginx/nginx-prometheus-exporter:latest
          args:
            - "-nginx.scrape-uri=http://127.0.0.1/metrics"
          ports:
            - containerPort: 9113
      
      volumes:
        - name: config-volume
          configMap:
            name: nginx-config